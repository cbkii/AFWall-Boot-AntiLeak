<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:background="?itemBackground"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.appcompat.widget.Toolbar
        android:id="@id/app_toolbar"
        android:background="?colorPrimary"
        android:layout_width="fill_parent"
        android:layout_height="?actionBarSize"
        android:minHeight="?actionBarSize" />
    <LinearLayout
        android:paddingLeft="10.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@id/app_icon"
            android:background="?android:selectableItemBackground"
            android:layout_width="38.0dip"
            android:layout_height="38.0dip"
            android:scaleType="fitCenter" />
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:paddingLeft="10.0dip"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <TextView
                android:textSize="18.0sp"
                android:textColor="?tint"
                android:id="@id/app_title"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
            <TextView
                android:textSize="12.0sp"
                android:textColor="?tint"
                android:id="@id/app_package"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16.0sp"
            android:textColor="?tint"
            android:paddingLeft="10.0dip"
            android:paddingTop="12.0dip"
            android:paddingBottom="6.0dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/traffic_detail_title" />
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6.0dip">
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="?tint"
                    android:gravity="center|right"
                    android:id="@id/table_header1"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:text="@string/uploaded"
                    android:layout_weight="2.0"
                    style="" />
                <TextView
                    android:textColor="?tint"
                    android:gravity="left"
                    android:id="@id/up"
                    android:layout_width="2.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="3.73"
                    style="" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textColor="?tint"
                    android:gravity="center|right"
                    android:id="@id/table_header2"
                    android:layout_width="0.0dip"
                    android:layout_height="fill_parent"
                    android:text="@string/downloaded"
                    android:layout_weight="1.0"
                    style="" />
                <TextView
                    android:textColor="?tint"
                    android:gravity="left"
                    android:id="@id/down"
                    android:layout_width="2.0dip"
                    android:layout_height="fill_parent"
                    android:layout_weight="1.83"
                    style="" />
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:id="@id/traffic_table"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@id/traffic_table1"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
    <LinearLayout
        android:padding="10.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <Button
            android:id="@id/app_settings"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:text="@string/app_system_detail"
            android:layout_weight="1.0" />
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center"
        android:background="?itemBackground"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <CheckBox
            android:id="@id/notification_p"
            android:layout_width="0.0dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10.0dip"
            android:text="@string/displayBlockNotification"
            android:layout_weight="1.0" />
    </LinearLayout>
</LinearLayout>