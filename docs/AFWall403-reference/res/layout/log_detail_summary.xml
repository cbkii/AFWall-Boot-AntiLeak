<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8.0dip"
    card_view:cardCornerRadius="8.0dip"
    card_view:cardElevation="4.0dip"
    card_view:cardUseCompatPadding="true"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16.0sp"
            android:textStyle="bold"
            android:textColor="?tint"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12.0dip"
            android:text="Block Summary" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:weightSum="3.0">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <TextView
                    android:textSize="24.0sp"
                    android:textStyle="bold"
                    android:textColor="?tint"
                    android:id="@id/total_blocks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="?tint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Blocks" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <TextView
                    android:textSize="24.0sp"
                    android:textStyle="bold"
                    android:textColor="?tint"
                    android:id="@id/unique_destinations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="?tint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destinations" />
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:layout_weight="1.0">
                <TextView
                    android:textSize="24.0sp"
                    android:textStyle="bold"
                    android:textColor="#ffff9800"
                    android:id="@id/time_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24h" />
                <TextView
                    android:textSize="12.0sp"
                    android:textColor="?tint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Period" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:background="#22757575"
            android:padding="8.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16.0dip">
            <TextView
                android:textSize="12.0sp"
                android:textStyle="bold"
                android:textColor="?tint"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:text="Most Blocked:" />
            <TextView
                android:textSize="14.0sp"
                android:textColor="?tint"
                android:id="@id/most_blocked_destination"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4.0dip"
                android:text="No data"
                android:fontFamily="monospace" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>