<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="horizontal"
        android:paddingTop="5.0dip"
        android:paddingBottom="5.0dip"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="true">
        <ImageView
            android:id="@id/itemicon"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_lan"
            android:padding="0.0px"
            android:visibility="gone"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_wifi"
            android:padding="0.0px"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_3g"
            android:padding="0.0px"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_roam"
            android:padding="0.0px"
            android:visibility="gone"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_vpn"
            android:padding="0.0px"
            android:visibility="gone"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_tether"
            android:padding="0.0px"
            android:visibility="gone"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <CheckBox
            android:id="@id/itemcheck_tor"
            android:padding="0.0px"
            android:visibility="gone"
            android:layout_width="32.0dip"
            android:layout_height="32.0dip" />
        <TextView
            android:id="@id/itemtext"
            android:paddingLeft="5.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="false" />
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@id/expanded_options"
        android:background="?android:selectableItemBackground"
        android:padding="12.0dip"
        android:visibility="gone"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8.0dip">
            <TextView
                android:textSize="12.0sp"
                android:textColor="?android:textColorSecondary"
                android:id="@id/blocked_count"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:text="Blocked: -"
                android:layout_weight="1.0" />
            <TextView
                android:textSize="12.0sp"
                android:gravity="end"
                android:id="@id/last_activity"
                android:layout_width="0.0dip"
                android:layout_height="wrap_content"
                android:text="Last activity: -"
                android:layout_weight="2.0" />
        </LinearLayout>
        <TextView
            android:textSize="12.0sp"
            android:textColor="?android:textColorSecondary"
            android:ellipsize="end"
            android:id="@id/last_blocked_destination"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4.0dip"
            android:text="Last blocked: -"
            android:maxLines="1" />
        <TextView
            android:textSize="12.0sp"
            android:textColor="?android:textColorSecondary"
            android:ellipsize="end"
            android:id="@id/data_usage"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8.0dip"
            android:text="Data usage: Loading..."
            android:maxLines="1" />
        <LinearLayout
            android:gravity="start"
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@id/action_toggle_log"
                android:background="?android:selectableItemBackgroundBorderless"
                android:padding="6.0dip"
                android:layout_width="36.0dip"
                android:layout_height="36.0dip"
                android:src="@drawable/ic_notifications_off_black_24dp"
                android:contentDescription="Toggle log notifications"
                android:layout_marginEnd="16.0dip" />
            <ImageView
                android:id="@id/action_open_app"
                android:background="?android:selectableItemBackgroundBorderless"
                android:padding="6.0dip"
                android:layout_width="36.0dip"
                android:layout_height="36.0dip"
                android:src="@drawable/ic_open_in_new_black_24dp"
                android:contentDescription="Open app settings"
                android:layout_marginEnd="16.0dip" />
            <ImageView
                android:id="@id/action_view_logs"
                android:background="?android:selectableItemBackgroundBorderless"
                android:padding="6.0dip"
                android:layout_width="36.0dip"
                android:layout_height="36.0dip"
                android:src="@drawable/ic_log"
                android:contentDescription="View firewall logs" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>