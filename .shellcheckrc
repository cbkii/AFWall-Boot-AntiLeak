# shellcheck configuration for AFWall Boot AntiLeak module scripts.
# These scripts target Android's BusyBox ash (#!/system/bin/sh).
# Ash supports 'local' (unlike strict POSIX sh), so SC3043 is not applicable.

# Treat scripts as ash by default so 'local' is accepted without warning.
shell=ash

# SC1090 / SC1091: Can't follow non-constant source / not following source.
# Module scripts source bin/common.sh and config.sh at runtime on-device.
# These paths are not available in CI; suppress the follow-source warnings.
disable=SC1090,SC1091

# SC2034: Variable appears unused.
# config.sh/customize.sh and installer helper variables are intentionally set
# for external consumers (Magisk installer or sourced config). Suppress false
# positives while keeping command/quoting checks active.
disable=SC2034

# SC2154: Variable is referenced but not assigned.
# action.sh, service.sh, post-fs-data.sh and uninstall.sh import module globals
# and functions through runtime-sourced common.sh/config.sh paths that ShellCheck
# does not follow in CI. Keep this scoped to the repository config rather than
# hiding it inline throughout every Magisk entrypoint.
disable=SC2154
